  client
);

    res.json(client);

  } catch (err) {
    res.status(500).json({
      error: err.message
    });
  }
});

const port =
  process.env.PORT || 4004;

app.listen(port, () => {
  console.log(
    `[client-crm] running on ${port}`
  );
});
