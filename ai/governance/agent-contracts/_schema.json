{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bluedoor.ai/schemas/agent-contract.json",
  "title": "BlueDoor Agent Contract",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "type": "string", "const": "bluedoor.ai/v1" },
    "kind": { "type": "string", "const": "AgentContract" },
    "metadata": {
      "type": "object",
      "required": ["name", "version", "owner", "domain"],
      "properties": {
        "name": { "type": "string", "pattern": "^bluedoor_[a-z0-9_]+_(agent|specialist)$" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "owner": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["mode", "description", "scope", "authority", "guardrails", "learning", "audit", "rollback"],
      "properties": {
        "mode": { "type": "string", "enum": ["agent", "specialist"] },
        "description": { "type": "string", "minLength": 10 },
        "scope": {
          "type": "object",
          "required": ["environments", "tenants", "data_access"],
          "properties": {
            "environments": {
              "type": "array",
              "items": { "type": "string", "enum": ["dev", "stage", "prod"] },
              "minItems": 1
            },
            "tenants": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "data_access": {
              "type": "object",
              "required": ["read", "write"],
              "properties": {
                "read": { "type": "array", "items": { "type": "string" } },
                "write": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "triggers": {
          "type": "object",
          "properties": {
            "event_subscriptions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["topic", "filter"],
                "properties": {
                  "topic": { "type": "string" },
                  "filter": { "type": "object" }
                },
                "additionalProperties": false
              }
            },
            "signal_rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "source", "expr", "severity"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "source": { "type": "string", "minLength": 1 },
                  "expr": { "type": "string", "minLength": 1 },
                  "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
                  "params": { "type": "object" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "authority": {
          "type": "object",
          "required": ["allowed_actions", "forbidden_actions"],
          "properties": {
            "allowed_actions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "description", "params_schema_ref"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "description": { "type": "string", "minLength": 5 },
                  "params_schema_ref": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              }
            },
            "forbidden_actions": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "guardrails": {
          "type": "object",
          "required": ["confidence_threshold", "require_human_approval", "rate_limits", "blast_radius", "safety_checks"],
          "properties": {
            "confidence_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
            "require_human_approval": {
              "type": "object",
              "required": ["default", "overrides"],
              "properties": {
                "default": { "type": "boolean" },
                "overrides": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["action_id", "required"],
                    "properties": {
                      "action_id": { "type": "string", "minLength": 1 },
                      "required": { "type": "boolean" }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            },
            "rate_limits": { "type": "object" },
            "blast_radius": { "type": "object" },
            "safety_checks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "required"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "required": { "type": "boolean" },
                  "params": { "type": "object" }
                },
                "additionalProperties": false
              }
            },
            "kill_switch": {
              "type": "object",
              "required": ["enabled", "path"],
              "properties": {
                "enabled": { "type": "boolean" },
                "path": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "learning": {
          "type": "object",
          "required": ["enabled", "mode", "promotion", "reward_signals", "constraints"],
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["offline", "shadow", "online"] },
            "promotion": {
              "type": "object",
              "required": ["required_shadow_runs", "max_regression_percent", "approval_required"],
              "properties": {
                "required_shadow_runs": { "type": "integer", "minimum": 0 },
                "max_regression_percent": { "type": "number", "minimum": 0 },
                "approval_required": { "type": "boolean" }
              },
              "additionalProperties": false
            },
            "reward_signals": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "goal", "weight"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "goal": { "type": "string", "enum": ["minimize", "maximize"] },
                  "weight": { "type": "number", "minimum": 0, "maximum": 1 }
                },
                "additionalProperties": false
              }
            },
            "constraints": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "audit": {
          "type": "object",
          "required": ["enabled", "sinks", "redact_fields", "retention_days"],
          "properties": {
            "enabled": { "type": "boolean" },
            "sinks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "redact_fields": { "type": "array", "items": { "type": "string" } },
            "retention_days": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "rollback": {
          "type": "object",
          "required": ["strategy", "playbook_ref"],
          "properties": {
            "strategy": { "type": "string", "minLength": 1 },
            "playbook_ref": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "definitions": {
        "ActionParams": {
          "type": "object",
          "properties": {
            "k8s.restart_deployment": {
              "type": "object",
              "required": ["namespace", "deployment"],
              "properties": {
                "namespace": { "type": "string" },
                "deployment": { "type": "string" }
              },
              "additionalProperties": false
            },
            "k8s.scale_deployment": {
              "type": "object",
              "required": ["namespace", "deployment", "replicas"],
              "properties": {
                "namespace": { "type": "string" },
                "deployment": { "type": "string" },
                "replicas": { "type": "integer", "minimum": 0, "maximum": 50 }
              },
              "additionalProperties": false
            },
            "traffic.freeze_writes": {
              "type": "object",
              "required": ["scope", "duration_seconds"],
              "properties": {
                "scope": { "type": "string", "enum": ["platform", "tenant", "service"] },
                "tenantId": { "type": "string" },
                "service": { "type": "string" },
                "duration_seconds": { "type": "integer", "minimum": 30, "maximum": 3600 }
              },
              "additionalProperties": false
            },
            "phoenix.trigger_backup": {
              "type": "object",
              "required": ["scope"],
              "properties": {
                "scope": { "type": "string", "enum": ["platform", "tenant", "service"] },
                "tenantId": { "type": "string" },
                "service": { "type": "string" }
              },
              "additionalProperties": false
            },
            "phoenix.trigger_restore": {
              "type": "object",
              "required": ["scope", "snapshot_id"],
              "properties": {
                "scope": { "type": "string", "enum": ["platform", "tenant", "service"] },
                "tenantId": { "type": "string" },
                "service": { "type": "string" },
                "snapshot_id": { "type": "string" }
              },
              "additionalProperties": false
            },
            "notify.admin": {
              "type": "object",
              "required": ["severity", "message"],
              "properties": {
                "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
                "message": { "type": "string", "minLength": 1 },
                "context": { "type": "object" }
              },
              "additionalProperties": false
            },
            "routing.optimize_vrp": {
              "type": "object",
              "required": ["date", "depot", "stops", "crews"],
              "properties": {
                "date": { "type": "string" },
                "depot": { "type": "object" },
                "stops": { "type": "array" },
                "crews": { "type": "array", "minItems": 1 }
              },
              "additionalProperties": true
            },
            "routing.publish_plan": {
              "type": "object",
              "required": ["date", "plan_id"],
              "properties": {
                "date": { "type": "string" },
                "plan_id": { "type": "string" }
              },
              "additionalProperties": false
            },
            "scheduling.reassign_job": {
              "type": "object",
              "required": ["jobId", "fromCrewId", "toCrewId"],
              "properties": {
                "jobId": { "type": "string" },
                "fromCrewId": { "type": "string" },
                "toCrewId": { "type": "string" }
              },
              "additionalProperties": false
            },
            "scheduling.adjust_eta": {
              "type": "object",
              "required": ["jobId", "eta_iso"],
              "properties": {
                "jobId": { "type": "string" },
                "eta_iso": { "type": "string" }
              },
              "additionalProperties": false
            },
            "notify.client_eta_update": {
              "type": "object",
              "required": ["clientId", "message"],
              "properties": {
                "clientId": { "type": "string" },
                "message": { "type": "string" }
              },
              "additionalProperties": false
            },
            "finance.flag_anomaly": {
              "type": "object",
              "required": ["entity_type", "entity_id", "reason"],
              "properties": {
                "entity_type": { "type": "string", "enum": ["invoice", "payment", "job", "client"] },
                "entity_id": { "type": "string" },
                "reason": { "type": "string" },
                "evidence": { "type": "object" }
              },
              "additionalProperties": false
            },
            "tasks.create": {
              "type": "object",
              "required": ["queue", "title", "severity"],
              "properties": {
                "queue": { "type": "string" },
                "title": { "type": "string" },
                "severity": { "type": "string", "enum": ["low", "medium", "high"] },
                "payload": { "type": "object" }
              },
              "additionalProperties": false
            },
            "notify.internal": {
              "type": "object",
              "required": ["channel", "message"],
              "properties": {
                "channel": { "type": "string" },
                "message": { "type": "string" },
                "context": { "type": "object" }
              },
              "additionalProperties": false
            },
            "notify.client_payment_reminder": {
              "type": "object",
              "required": ["clientId", "message"],
              "properties": {
                "clientId": { "type": "string" },
                "message": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "additionalProperties": false
}
